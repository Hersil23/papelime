# ════════════════════════════════════════════════════════════════
# Papelime — Static site .htaccess
# Server: LiteSpeed (cPanel)
# ════════════════════════════════════════════════════════════════

# ── Force HTTPS ─────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Drop trailing .html when a folder version exists
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI:s/\.html$//}/index.html -f
  RewriteRule ^(.+)\.html$ /$1/ [L,R=301]
</IfModule>

# ── Security headers ────────────────────────────────────────────
<IfModule mod_headers.c>
  # HSTS — force HTTPS for 1 year, include subdomains, preload-ready
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Clickjacking protection
  Header set X-Frame-Options "SAMEORIGIN"

  # Referrer policy — only send origin on cross-origin requests
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable invasive browser features by default
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=()"

  # XSS protection (legacy but harmless on modern browsers)
  Header set X-XSS-Protection "1; mode=block"

  # CORS — same-origin only for resources
  Header set Cross-Origin-Opener-Policy "same-origin"

  # Don't leak server signature
  Header unset X-Powered-By
  Header always unset X-Powered-By
</IfModule>

# ── Compression ─────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml application/ld+json
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml application/ld+json
</IfModule>

# ── Cache control ───────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: short cache, must revalidate
  ExpiresByType text/html "access plus 0 seconds"

  # CSS / JS: 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"

  # Images: 1 year (immutable assets)
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts: 1 year
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"

  # Manifest / sitemap / robots / llms: 1 day
  ExpiresByType application/manifest+json "access plus 1 day"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Long-cache + immutable for hashed/versioned assets
  <FilesMatch "\.(webp|jpe?g|png|svg|woff2?|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS/JS: revalidate after 1 month
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML: always revalidate so users see fresh content
  <FilesMatch "\.html?$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ── MIME types ──────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/webp .webp
  AddType text/plain .txt
</IfModule>

# ── Block dotfiles (.git, .env, .htaccess) from public access ──
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Explicit allow for .well-known (Let's Encrypt, etc.)
<IfModule mod_alias.c>
  <Directory ~/.well-known>
    Require all granted
  </Directory>
</IfModule>

# ── Custom error pages ──────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Default index files ─────────────────────────────────────────
DirectoryIndex index.html index.htm
